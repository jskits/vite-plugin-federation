{
  "name": "vite-plugin-federation-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for building vite-plugin-federation.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "clean": "turbo run clean && rimraf .turbo coverage",
    "commit": "cz",
    "changeset": "changeset",
    "dev": "turbo run dev --parallel",
    "examples:build": "pnpm --filter example-react-remote build && pnpm --filter example-react-host build && pnpm --filter example-react-ssr-host build && pnpm examples:dts:build",
    "examples:dts:build": "pnpm --filter vite-plugin-federation build && pnpm --filter example-dts-remote test:invalid-types && pnpm --filter example-dts-remote test:artifacts && pnpm --filter example-dts-host test:types && pnpm --filter example-dts-host test:types:failures",
    "examples:ssr:build": "pnpm --filter example-react-remote build && pnpm --filter example-react-ssr-host build",
    "examples:dev": "turbo run dev --parallel --filter=example-react-remote --filter=example-react-host",
    "format": "prettier . --cache --write",
    "format:check": "prettier . --cache --check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "prepare": "husky",
    "release": "pnpm --filter vite-plugin-federation build && changeset publish",
    "test": "turbo run test",
    "test:vite-matrix:smoke": "node scripts/vite-peer-matrix-smoke.mjs",
    "test:package:smoke": "node scripts/package-smoke-test.mjs",
    "test:e2e": "pnpm --filter vite-plugin-federation test:e2e",
    "test:watch": "turbo run test:watch --parallel",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "overrides": {
    "commitizen": {
      "inquirer": "8.2.7",
      "lodash": "4.18.1"
    }
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "@types/node": "25.6.0",
    "commitizen": "4.3.1",
    "cz-git": "1.12.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "pathe": "2.0.3",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "rollup": "4.52.4",
    "tsup": "8.5.1",
    "turbo": "2.9.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.4"
  }
}
